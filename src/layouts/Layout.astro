---
import "../styles/global.css";
import Navbar from "../components/commons/navbar/navbar.astro";
import Footer from "../components/commons/footer/footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mario de la Rosa",
  description = "Portfolio de Mario de la Rosa — Desarrollador Full Stack especializado en frontend, React, Node.js y diseño UX/UI.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mario de la Rosa" />
    <meta property="og:title" content={`${title} | Mario de la Rosa`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL("/og-image.png", Astro.url).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Mario de la Rosa`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-image.png", Astro.url).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <meta name="theme-color" content="#ffffff" />
    <title>{title} | Mario de la Rosa</title>
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('lang') || 'es';
        document.documentElement.setAttribute('lang', lang);
      })();
    </script>
  </head>
  <body class="bg-white text-gray-900">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<script>
  function initReveal() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("reveal-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
  }

  initReveal();
  document.addEventListener("astro:page-load", initReveal);

  function initLangToggle() {
    const btn = document.getElementById("lang-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("lang");
      const next = current === "es" ? "en" : "es";
      document.documentElement.setAttribute("lang", next);
      localStorage.setItem("lang", next);
    });
  }
  initLangToggle();
  document.addEventListener("astro:page-load", initLangToggle);
</script>
