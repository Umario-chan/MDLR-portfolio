---
import Layout from "../../layouts/Layout.astro";
import { HiArrowLeft, HiArrowUpRight } from "react-icons/hi2";
import { FaGithub } from "react-icons/fa6";
import { proyectos } from "../../data/projectData.js";

export async function getStaticPaths() {
  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.slug },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props;
const { titulo, subtitulo, descripcion, descripcionLarga, secciones, imagen, tecnologias, demo, categoria, wip } = proyecto;
---

<Layout title={titulo} description={descripcion}>
  <section class="min-h-screen bg-white pt-28 pb-20 px-6">
    <div class="max-w-4xl mx-auto">

      <a
        href="/proyectos"
        class="inline-flex items-center gap-2 text-sm font-semibold text-gray-400 hover:text-[#1a6fec] transition-colors duration-200 mb-10 group"
      >
        <HiArrowLeft size={16} className="group-hover:-translate-x-1 transition-transform duration-200" />
        Volver a proyectos
      </a>

      {wip ? (
        <div class="flex flex-col items-center justify-center text-center py-24 gap-6">
          <div class="overflow-hidden rounded-2xl border border-gray-200 shadow-sm w-full mb-4">
            <img
              src={imagen}
              alt={`Captura del proyecto ${titulo}`}
              class="w-full object-cover max-h-[360px] opacity-60 grayscale"
            />
          </div>
          <span class="text-[10px] font-semibold tracking-[0.2em] uppercase text-[#1a6fec]">
            Work in progress
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">{titulo}</h1>
          <p class="text-gray-400 text-base max-w-md">
            Este proyecto está en construcción. Pronto estará disponible con todos sus detalles.
          </p>
          <div class="flex items-center gap-2 mt-2">
            <span class="h-2 w-2 rounded-full bg-[#1a6fec] animate-pulse"></span>
            <span class="text-sm font-semibold text-gray-500">Coming soon</span>
          </div>
        </div>
      ) : (
        <>
          <div class="mb-6">
            {categoria && (
              <span class="text-[10px] font-semibold tracking-[0.2em] uppercase text-[#1a6fec]">
                {categoria}
              </span>
            )}
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-2 leading-tight">{titulo}</h1>
          </div>

          <div class="overflow-hidden rounded-2xl border border-gray-200 mb-10 shadow-sm">
            <img
              src={imagen}
              alt={`Captura del proyecto ${titulo}`}
              class="w-full object-cover max-h-[480px]"
            />
          </div>

          <div class="grid md:grid-cols-3 gap-12">
            <div class="md:col-span-2 space-y-8">
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#1a6fec] mb-3">
                  Sobre el proyecto
                </p>
                {subtitulo && (
                  <p class="text-lg font-semibold text-gray-800 mb-2">{subtitulo}</p>
                )}
                <p class="text-gray-600 text-base leading-relaxed">
                  {descripcionLarga ?? descripcion}
                </p>
              </div>

              {secciones && secciones.length > 0 && (
                <div>
                  <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#1a6fec] mb-5">
                    Flujos principales
                  </p>
                  <div class="space-y-6">
                    {secciones.map((seccion) => (
                      <div>
                        <p class="text-sm font-bold text-gray-800 mb-2">{seccion.titulo}</p>
                        <ul class="space-y-1.5">
                          {seccion.items.map((item) => (
                            <li class="flex gap-2 text-sm text-gray-600 leading-relaxed">
                              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[#1a6fec]"></span>
                              {item}
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <aside class="flex flex-col gap-6">
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-400 mb-3">
                  Tecnologías
                </p>
                <div class="flex flex-wrap gap-2">
                  {tecnologias.map((tech) => (
                    <span class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full font-medium">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              {demo && (
                <div class="flex flex-col gap-3">
                  <a
                    href={demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-semibold text-white bg-[#1a6fec] hover:bg-[#1255c4] px-5 py-2.5 rounded-xl transition-colors duration-200"
                  >
                    Ver proyecto en vivo
                    <HiArrowUpRight size={15} />
                  </a>
                  <span class="inline-flex items-center gap-2 text-sm font-semibold text-gray-700 border border-gray-200 px-5 py-2.5 rounded-xl cursor-not-allowed opacity-50">
                    <FaGithub size={15} />
                    GitHub
                  </span>
                </div>
              )}
            </aside>
          </div>
        </>
      )}

    </div>
  </section>
</Layout>
