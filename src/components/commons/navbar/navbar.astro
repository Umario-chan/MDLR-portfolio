---
import { FiMenu, FiX } from "react-icons/fi";
import { FaLinkedinIn, FaGithub } from "react-icons/fa6";

const links = [
  { name: "Inicio", href: "/" },
  { name: "Proyectos", href: "/proyectos" },
];
---

<nav class="relative">
  <input id="menu-toggle" type="checkbox" class="peer hidden md:hidden" />

  <nav class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center">
        <h3 class="text-[#1a6fec] text-2xl font-bold tracking-tight">MDLR</h3>
      </a>

      <ul id="navbar-links" class="hidden md:flex items-center space-x-8">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link text-base font-semibold text-gray-600 hover:text-[#1a6fec] transition-colors duration-200"
              >
                {link.name}
              </a>
            </li>
          ))
        }

        <li class="flex items-center gap-3">
          <a
            href="https://www.linkedin.com/in/mdlr89/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-gray-400 hover:text-[#1a6fec] transition-colors"
          >
            <FaLinkedinIn className="h-5 w-5" />
          </a>
          <a
            href="https://github.com/Umario-chan"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-gray-400 hover:text-[#1a6fec] transition-colors"
          >
            <FaGithub className="h-5 w-5" />
          </a>
        </li>
      </ul>

      <div class="flex md:hidden items-center gap-4 z-50">
        <label for="menu-toggle" class="cursor-pointer text-gray-600">
          <FiMenu className="h-6 w-6" />
        </label>
      </div>
    </div>
  </nav>

  <label
    for="menu-toggle"
    class="fixed inset-0 bg-black/30 hidden peer-checked:block cursor-pointer z-40 md:hidden"
  ></label>

  <div
    class="fixed top-0 right-0 h-full w-64 bg-white border-l border-gray-200 shadow-xl transform translate-x-full transition-transform duration-300 peer-checked:translate-x-0 z-50 md:translate-x-full md:hidden"
  >
    <div class="flex justify-end p-4">
      <label for="menu-toggle" class="cursor-pointer text-gray-500">
        <FiX className="h-6 w-6" />
      </label>
    </div>

    <ul id="navbar-links-mobile" class="flex flex-col space-y-6 mt-6 ml-6">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link-mobile text-lg font-semibold text-gray-800 hover:text-[#1a6fec] transition-colors duration-200"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  (function () {
    function markActiveLinks() {
      const currentPath = window.location.pathname.replace(/\/$/, "") || "/";
      const allLinks = [
        ...Array.from(document.querySelectorAll("#navbar-links .nav-link")),
        ...Array.from(document.querySelectorAll("#navbar-links-mobile .nav-link-mobile")),
      ];
      allLinks.forEach((link) => {
        const href = (link.getAttribute("href") ?? "").replace(/\/$/, "") || "/";
        if (href === currentPath) {
          link.classList.add("text-[#1a6fec]", "font-semibold");
          link.classList.remove("text-gray-600", "text-gray-800");
        } else {
          link.classList.remove("text-[#1a6fec]", "font-semibold");
        }
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", markActiveLinks);
    } else {
      markActiveLinks();
    }
    window.addEventListener("popstate", markActiveLinks);
    document.addEventListener("astro:page-load", markActiveLinks);
    document.addEventListener("astro:after-swap", markActiveLinks);
    window.addEventListener("load", () => setTimeout(markActiveLinks, 50));
  })();
</script>
