---
import { FaLinkedinIn, FaGithub } from "react-icons/fa6";
---

<footer class="bg-gray-50 border-t border-gray-200">
  <div class="max-w-7xl mx-auto flex flex-col items-center justify-between gap-6 px-6 py-10 md:flex-row">
    <a href="/" class="flex items-center">
      <span class="text-[#1a6fec] text-xl font-bold tracking-tight">MDLR</span>
    </a>

    <nav>
      <ul class="flex flex-wrap justify-center items-center gap-x-6 gap-y-2 text-sm text-gray-500">
        <li>
          <a href="/" class="hover:text-gray-900 transition-colors">
            <span class="lang-es">Inicio</span>
            <span class="lang-en">Home</span>
          </a>
        </li>
        <li>
          <a href="/proyectos" class="hover:text-gray-900 transition-colors">
            <span class="lang-es">Proyectos</span>
            <span class="lang-en">Projects</span>
          </a>
        </li>
        <li>
          <a href="/experiencia" class="hover:text-gray-900 transition-colors">
            <span class="lang-es">Experiencia</span>
            <span class="lang-en">Experience</span>
          </a>
        </li>
        <li>
          <a href="/contact" class="hover:text-gray-900 transition-colors">
            <span class="lang-es">Contacto</span>
            <span class="lang-en">Contact</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="flex items-center gap-4">
      <a href="https://www.linkedin.com/in/mdlr89/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gray-400 hover:text-[#1a6fec] transition-colors">
        <FaLinkedinIn className="h-5 w-5" />
      </a>
      <a href="https://github.com/Umario-chan" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-gray-400 hover:text-[#1a6fec] transition-colors">
        <FaGithub className="h-5 w-5" />
      </a>
    </div>
  </div>
</footer>
