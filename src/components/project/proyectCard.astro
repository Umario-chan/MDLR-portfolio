---
export interface Props {
  titulo: string;
  descripcion: string;
  imagen: string;
  tecnologias: string[];
  slug: string;
  categoria?: string;
  index: number;
}

const { titulo, descripcion, imagen, tecnologias, slug, categoria, index } = Astro.props;
---

<a
  href={`/proyectos/${slug}`}
  data-index={index}
  data-categoria={categoria ?? ""}
  class="project-card group flex w-full sm:w-[360px] flex-col overflow-hidden rounded-2xl bg-white border border-gray-200 transition-all duration-300 hover:border-[#1a6fec]/40 hover:shadow-xl hover:shadow-[#1a6fec]/10 hover:-translate-y-1 cursor-pointer no-underline"
>
  <div class="overflow-hidden bg-gray-50">
    <img
      src={imagen}
      alt={`Imagen del proyecto ${titulo}`}
      class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>

  <div class="flex flex-col grow p-5">
    {categoria && (
      <span class="text-[10px] font-semibold tracking-[0.15em] uppercase text-[#1a6fec] mb-2">
        {categoria}
      </span>
    )}

    <h3 class="text-gray-900 font-bold text-lg leading-snug mb-2">{titulo}</h3>

    <p class="text-gray-500 text-sm leading-relaxed grow mb-4">{descripcion}</p>

    <div class="flex flex-wrap gap-1.5">
      {
        tecnologias.map((tech) => (
          <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-full font-medium">
            {tech}
          </span>
        ))
      }
    </div>
  </div>
</a>
