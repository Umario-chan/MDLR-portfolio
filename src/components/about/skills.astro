<section class="mt-16 mx-auto max-w-5xl px-6 reveal">
  <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#1a6fec] mb-1">Stack</p>
  <h2 class="text-3xl font-bold text-gray-900 mb-10">Tecnologías</h2>

  <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-4">
    {
      [
        { name: "HTML", icon: "html5" },
        { name: "CSS", icon: "css3" },
        { name: "JavaScript", icon: "javascript" },
        { name: "TypeScript", icon: "typescript" },
        { name: "Python", icon: "python" },
        { name: "React", icon: "react" },
        { name: "Vue", icon: "vuejs" },
        { name: "Astro", icon: "astro" },
        { name: "Next.js", icon: "nextjs" },
        { name: "Tailwind", icon: "tailwindcss" },
        { name: "Node.js", icon: "nodejs" },
        { name: "Express", icon: "express" },
        { name: "MongoDB", icon: "mongodb" },
        { name: "MySQL", icon: "mysql" },
        { name: "PostgreSQL", icon: "postgresql" },
        { name: "Git", icon: "git" },
      ].map((skill) => (
        <div class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 bg-white hover:border-[#1a6fec]/40 hover:shadow-sm transition-all duration-200 group">
          <img
            src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${skill.icon}/${skill.icon}-original.svg`}
            alt={skill.name}
            class="w-9 h-9"
          />
          <p class="text-xs text-gray-500 font-medium text-center group-hover:text-gray-900 transition-colors">{skill.name}</p>
        </div>
      ))
    }
  </div>
</section>
