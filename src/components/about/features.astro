---
import ServiceCard from "./ServiceCard.astro";
import { FaLaptopCode, FaBolt, FaRocket } from "react-icons/fa";
---

<section class="mt-16 mx-auto max-w-5xl px-6 reveal">
  <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#1a6fec] mb-1">Qué ofrezco</p>
  <h2 class="text-3xl font-bold text-gray-900 mb-10">Servicios</h2>

  <div class="grid gap-5 md:grid-cols-3">
    <ServiceCard
      icon={FaLaptopCode}
      title="Desarrollo Web Responsivo"
      description="Construcción de sitios web modernos, adaptados a dispositivos móviles, optimizados y con tecnologías actuales."
    />
    <ServiceCard
      icon={FaBolt}
      title="Frontend"
      description="Desarrollo de interfaces modernas, rápidas y accesibles que ofrecen una experiencia de usuario intuitiva y atractiva."
    />
    <ServiceCard
      icon={FaRocket}
      title="Backend"
      description="Rendimiento rápido, mejores prácticas de accesibilidad y optimización de procesos en el servidor."
    />
  </div>
</section>
