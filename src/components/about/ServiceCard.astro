---
interface Props {
  icon: any;
  title: string;
  description: string;
}

const { icon: Icon, title, description } = Astro.props;
---

<div class="group flex flex-col gap-4 rounded-2xl border border-gray-200 bg-white p-6 hover:border-[#1a6fec]/30 hover:shadow-md transition-all duration-300">
  <div class="w-10 h-10 rounded-xl bg-[#1a6fec]/10 flex items-center justify-center text-[#1a6fec]">
    {Icon && <Icon size={20} />}
  </div>
  <div>
    <h3 class="font-bold text-gray-900 mb-1">{title}</h3>
    <p class="text-sm text-gray-500 leading-relaxed">{description}</p>
  </div>
</div>
