---
const githubUrl = "https://github.com/Umario-chan";
const imageUrl = "/github.png";
---

<section class="mt-16 px-6 reveal">
  <div class="mx-auto max-w-5xl overflow-hidden rounded-2xl border border-gray-200 bg-gray-900 flex flex-col md:flex-row-reverse items-center">
    <div class="flex shrink-0 items-center justify-center p-6 md:p-0">
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">
        <img
          src={imageUrl}
          alt="GitHub"
          class="h-auto w-48 md:w-64 object-contain opacity-90 hover:opacity-100 transition-opacity"
        />
      </a>
    </div>

    <div class="flex-1 p-8 text-center md:text-left">
      <h3 class="text-2xl md:text-3xl font-bold text-white mb-2">¡Visita mi GitHub!</h3>
      <p class="text-gray-400 text-sm mb-6">
        Explora mis proyectos y contribuciones más recientes.
      </p>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-gray-900 font-semibold text-sm px-6 py-2.5 rounded-full hover:bg-gray-100 transition-colors"
      >
        Ir a GitHub
      </a>
    </div>
  </div>
</section>
