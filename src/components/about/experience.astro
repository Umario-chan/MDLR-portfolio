---
import "../../styles/experiencie.css";
import { jobs } from "../../data/jobsData";
---

<section class="experience mt-16 mx-auto max-w-5xl px-6 reveal">
  <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#1a6fec] mb-1">Trayectoria</p>
  <h2 class="text-3xl font-bold text-gray-900 mb-0">Mi Experiencia</h2>

  <section class="jobs">
    <div class="job-title">
      {
        jobs.map((job, index) => (
          <button
            class={`tabbutton ${index === 0 ? "active" : ""}`}
            aria-selected={index === 0 ? "true" : "false"}
            data-index={index}
          >
            {job.title}
          </button>
        ))
      }
    </div>

    <div class="jobs-descriptions">
      {
        jobs.map(({ title, time, description, list }, index) => (
          <div
            class={`description tabcontent ${index === 0 ? "active" : ""}`}
            data-index={index}
          >
            <h3 class="mb-1 text-xl font-bold text-gray-900">{title}</h3>
            <div class="job-time">
              {time.map((t) => (
                <time class="text-sm text-gray-400" datetime={t}>{t}</time>
              ))}
            </div>
            <p class="mb-3 text-sm text-gray-600 leading-relaxed">{description}</p>
            <ul class="list-disc space-y-1.5 pl-5 text-sm text-gray-600 marker:text-[#1a6fec]">
              {list.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</section>

<script>
  import { initExperienceTabs } from "../../scripts/experienceTabs.js";
  initExperienceTabs();
  document.addEventListener("astro:after-swap", initExperienceTabs);
</script>
