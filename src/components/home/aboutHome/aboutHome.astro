---
import { HiArrowRight } from "react-icons/hi";
import MiFoto from "../../../assets/img/MiFoto.png";
---

<section class="py-16 px-4 bg-gray-50 border-y border-gray-200 reveal">
  <div class="mx-auto flex max-w-5xl flex-col-reverse items-center gap-10 md:flex-row">
    <div class="flex-1">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Sobre Mí</h2>
      <p class="text-gray-500 leading-relaxed text-sm md:text-base">
        Mi nombre es Mario, soy Desarrollador de Software y actualmente me
        desempeño como Web Developer, con un enfoque en el Frontend y la
        experiencia del usuario. Trabajo con tecnologías como React, Node.js,
        Astro, JavaScript, TypeScript, Cypress, Tailwind CSS, SASS, Figma,
        entre otras.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#1a6fec] hover:gap-3 transition-all duration-200"
      >
        Contáctame
        <HiArrowRight size={16} />
      </a>
    </div>

    <div class="flex flex-col items-center gap-3 shrink-0">
      <div class="w-48 h-48 md:w-64 md:h-64 overflow-hidden rounded-2xl border border-gray-200 shadow-sm">
        <img src={MiFoto.src} alt="Foto de Mario" class="h-full w-full object-cover" />
      </div>
      <div class="text-center">
        <p class="text-xs font-semibold text-gray-700">Lic. en Ing. en Sistemas Computacionales</p>
        <p class="text-xs text-gray-400 mt-0.5">Cédula Profesional: 7453612</p>
      </div>
    </div>
  </div>
</section>
