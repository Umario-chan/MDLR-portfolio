---
import HomeProjectCard from "./homeProyectCard.astro";
import { proyectos } from "../../../data/projectData.js";
---

<section class="py-16 px-4 reveal">
  <div class="max-w-5xl mx-auto">
    <div class="mb-10 flex items-end justify-between px-2">
      <div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#1a6fec] mb-1">Trabajo reciente</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Proyectos destacados</h2>
      </div>
      <a
        href="/proyectos"
        class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold text-[#1a6fec] hover:gap-3 transition-all duration-200"
      >
        Ver todos
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {proyectos.map((p) => <HomeProjectCard {...p} />)}
    </div>

    <div class="mt-8 flex justify-center md:hidden">
      <a
        href="/proyectos"
        class="inline-flex items-center gap-2 px-6 py-2.5 border border-gray-300 rounded-full text-sm font-semibold text-gray-700 hover:border-[#1a6fec] hover:text-[#1a6fec] transition-all duration-200"
      >
        Ver todos los proyectos
      </a>
    </div>
  </div>
</section>
