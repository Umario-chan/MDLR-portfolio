---
import { HiArrowUpRight } from "react-icons/hi2";

export interface Props {
  titulo: string;
  imagen: string;
  tecnologias: string[];
  slug: string;
  codigo?: string;
}

const { titulo, imagen, tecnologias, slug } = Astro.props;
---

<a href={`/proyectos/${slug}`} class="group flex w-full max-w-md mx-auto flex-col overflow-hidden rounded-2xl bg-white border border-gray-200 transition-all duration-300 hover:border-[#1a6fec]/40 hover:shadow-xl hover:shadow-[#1a6fec]/10 hover:-translate-y-1 no-underline cursor-pointer">
  <div class="overflow-hidden bg-gray-50">
    <img
      src={imagen}
      alt={`Proyecto: ${titulo}`}
      class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>

  <div class="flex flex-col p-4">
    <h3 class="text-gray-900 font-bold text-base mb-2">{titulo}</h3>

    <div class="flex flex-wrap gap-1.5 mb-4">
      {
        tecnologias.map((tech) => (
          <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-full font-medium">
            {tech}
          </span>
        ))
      }
    </div>

    <span class="inline-flex items-center gap-1 text-sm font-semibold text-[#1a6fec] group-hover:gap-2 transition-all duration-200">
      <span class="lang-es">Ir al proyecto</span>
      <span class="lang-en">View project</span>
      <HiArrowUpRight size={14} />
    </span>
  </div>
</a>
