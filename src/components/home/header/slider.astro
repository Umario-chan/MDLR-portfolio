---
const technologies = [
  "astro", "react", "typeScript", "tailwindcss", "nodejs",
  "HTML5", "CSS3", "javaScript", "git", "mysql",
];
---

<div class="relative overflow-x-hidden border-y border-gray-100 bg-gray-50 py-5">
  <div class="animate-scroll hover:animate-paused flex w-max gap-10">
    {
      technologies.concat(technologies, technologies).map((tech) => (
        <div class="flex items-center gap-2.5 text-gray-500">
          <img
            src={`/svg/${tech}.svg`}
            alt={tech}
            class="h-5 w-auto object-contain opacity-70"
            width="20"
            height="20"
            loading="lazy"
          />
          <span class="text-sm font-medium whitespace-nowrap">
            {tech.charAt(0).toUpperCase() + tech.slice(1)}
          </span>
        </div>
      ))
    }
  </div>
</div>

<style is:global>
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-33.33%); }
  }
  .animate-scroll {
    animation: scroll 50s linear infinite;
  }
  .hover\:animate-paused:hover {
    animation-play-state: paused;
  }
</style>
